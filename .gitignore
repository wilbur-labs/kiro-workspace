# Sensitive files
.claude/
*.env
*.pem
id_rsa*
id_ed25519*

# Binary tools
*.exe

# AI-DLC generated artifacts (per-task, regenerable)
**/aidlc-docs/*
!**/aidlc-docs/.gitkeep

# User-generated content (not part of template)
# (code-quality-reviewer + dogfood-todo-api are template-shipped — kept out of the wildcard ignore)
/.kiro/agents/*.json
!/.kiro/agents/example.json
!/.kiro/agents/code-quality-reviewer.json
!/.kiro/agents/dogfood-todo-api.json
/.kiro/prompts/*.md
!/.kiro/prompts/example.md
!/.kiro/prompts/code-quality-reviewer.md
!/.kiro/prompts/dogfood-todo-api.md
/.kiro/learned/LEARNED.md
/.kiro/shared/SHARED-CONTEXT.md

# Task directories (users create their own)
/tasks/*/
!/tasks/example/
!/tasks/dogfood-todo-api/
